NODE_ENV=development
PORT=3000
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/mercado
AUTH0_DOMAIN=your-tenant.eu.auth0.com
AUTH0_AUDIENCE=https://api.mercado.example
LOG_LEVEL=debug
CORS_ORIGIN=http://localhost:5173
# Public base URL for S3 product image assets (bucket public endpoint or CDN).
# HTTPS is required in production. http:// is accepted for local dev (MinIO / LocalStack).
S3_PUBLIC_BASE_URL=https://cdn.example.com

# Docker Compose PostgreSQL (used by docker-compose.yml)
POSTGRES_DB=mercado
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
